# Create predictor matrix
X <- dendro_clean[dendro_clean,
which(names(dendro_clean) == "1nm_398"):
which(names(dendro_clean) == "Vogelmann4_15nm_Median")]
# Create predictor matrix
X <- dendro_clean[
which(names(dendro_clean) == "1nm_398"):
which(names(dendro_clean) == "Vogelmann4_15nm_Median")]
View(X)
X <- as.data.frame(X)
#### 1) VSURF + RF FOR TWD_DRONE
# Response
Y_twd <- dendro_clean$TWD_drone[complete_idx]
#### 1) VSURF + RF FOR TWD_DRONE
# Response
Y_twd <- dendro_clean$TWD_drone[dendro_clean]
#### 1) VSURF + RF FOR TWD_DRONE
# Response
Y_twd <- dendro_clean$TWD_drone
# VSURF VARIABLE SELECTION
set.seed(123)
vsurf_twd <- VSURF(
x = X,
y = Y_twd,
ntree = 1000,
